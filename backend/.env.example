# Database Configuration (PlanetScale MySQL)
DATABASE_URL=mysql+pymysql://username:password@psdb-host:3306/database_name?ssl=%7B%22ca%22%3A%22%2Fpath%2Fto%2Fca-cert.pem%22%2C%22cert%22%3A%2Fpath%2Fto%2Fclient-cert.pem%22%2C%22key%22%3A%22%2Fpath%2Fto%2Fclient-key.pem%22%7D

# FastAPI Configuration
HOST=0.0.0.0
PORT=8000
DEBUG=False

# Frontend Configuration
FRONTEND_URL=http://localhost:3000

# WhatsApp Configuration
WHATSAPP_API_TOKEN=your_whatsapp_api_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WEBHOOK_VERIFY_TOKEN=your-webhook-verification-token

# Secret Key for Admin Authentication (JWT)
SECRET_KEY=your-secret-key-change-in-production

